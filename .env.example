# =============================================================================
# Employee Management — configuration template
# Copy to .env.dev / .env.stage / .env.prod and fill per environment.
# NEVER commit real secrets; only this template is tracked in VCS.
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=employee_db
POSTGRES_PORT=5432

# ---- Backend ----
DATABASE_URL=postgresql://postgres:postgres@db:5432/employee_db
JWT_SECRET=change-me-generate-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:8080
LOG_LEVEL=info
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me
BACKEND_PORT=8000

# ---- Frontend ----
FRONTEND_PORT=8080

# ---- Image / registry (used by docker-compose.prod.yml and scripts) ----
# REGISTRY examples: docker.io/youruser | myregistry.azurecr.io | 123.dkr.ecr.us-east-1.amazonaws.com | localhost:5000
REGISTRY=employee-management
VERSION=1.0.0

# ---- Resource limits (production compose) ----
BACKEND_CPU_LIMIT=1.0
BACKEND_MEM_LIMIT=512M
FRONTEND_CPU_LIMIT=0.5
FRONTEND_MEM_LIMIT=128M
DB_CPU_LIMIT=1.0
DB_MEM_LIMIT=512M
